# Copy to .env and fill in. NEVER commit the real .env (it's gitignored).

# OIDC provider issuer. Discovery is read from <issuer>/.well-known/openid-configuration
#   Entra ID: https://login.microsoftonline.com/<tenant-id>/v2.0
#   Okta:     https://<org>.okta.com/oauth2/default
#   Auth0:    https://<tenant>.us.auth0.com
#   Google:   https://accounts.google.com
OIDC_ISSUER=

OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:8000/auth/callback
OIDC_SCOPES=openid profile email

# Signing key for the session cookie. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=

# Set to true when serving over HTTPS (production) so the cookie gets the Secure flag.
COOKIE_SECURE=false
