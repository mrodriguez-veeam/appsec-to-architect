# Copy to .env. Resource-server validation settings.

# Where to fetch signing keys, and what to require on every token.
# Defaults point at the local dev issuer (devissuer/) for offline testing.
JWKS_URL=http://localhost:9000/.well-known/jwks.json
TOKEN_ISSUER=https://dev-issuer.local
TOKEN_AUDIENCE=resource-api

# To validate REAL tokens instead, point these at your IdP. Example (Entra ID):
#   JWKS_URL=https://login.microsoftonline.com/<tenant-id>/discovery/v2.0/keys
#   TOKEN_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
#   TOKEN_AUDIENCE=<your API's Application ID URI or client id>
